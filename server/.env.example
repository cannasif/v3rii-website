# Gmail yapılandırması
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-app-password

# Server yapılandırması
PORT=3001

# GMAIL APP PASSWORD NASIL ALINIR:
# 1. Gmail hesabınıza gidin
# 2. Google Account Settings > Security
# 3. 2-Step Verification'ı aktif edin
# 4. App passwords bölümünden yeni bir app password oluşturun
# 5. Bu password'ü EMAIL_PASS olarak kullanın